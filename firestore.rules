rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Raíz por defecto del sitio: prod (si usas otra, duplica estos bloques cambiando el primer segmento)
    match /prod/admin/conferences/{docId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /prod/admin/projects/{docId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }
  }
}
