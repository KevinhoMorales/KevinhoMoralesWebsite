# =============================================================================
# YouTube Data API v3 - para podcast DevLokos (episodios)
# Parámetro en Remote Config: youtube_api_key
# Get key at: https://console.cloud.google.com/apis/credentials
# =============================================================================
YOUTUBE_API_KEY=your_youtube_api_key

# =============================================================================
# Web3Forms - REQUERIDO para que el formulario de contacto funcione
# 1. Ir a https://web3forms.com → crear cuenta → crear access key
# 2. Pegar la key aquí (reemplazar your_web3forms_access_key)
# 3. Reiniciar el servidor (npm run dev)
# =============================================================================
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# =============================================================================
# Firebase Admin SDK - necesario para leer Remote Config (web_3_form, youtube_api_key)
# Firebase Console → Project Settings → Service accounts → Generate new private key
# El JSON completo entre comillas simples (recomendado en Vercel y local)
# =============================================================================
# FIREBASE_ADMIN_SDK_KEY='{"type":"service_account","project_id":"...",...}'
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firebase - for podcast cache, analytics, future CMS
# Get config at: https://console.firebase.google.com/ → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=devlokos.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=devlokos
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=devlokos.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=458512617441
NEXT_PUBLIC_FIREBASE_APP_ID=1:458512617441:web:4c7111eb0b20a66f9c8ca0
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-0PHWYP1KV7
