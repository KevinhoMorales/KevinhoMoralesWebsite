# =============================================================================
# YouTube Data API v3 - para podcast DevLokos (episodios)
# Parámetro en Remote Config: youtube_api_key
# Get key at: https://console.cloud.google.com/apis/credentials
# =============================================================================
YOUTUBE_API_KEY=your_youtube_api_key

# =============================================================================
# Web3Forms — correo al enviar contacto y lista de espera (desde el navegador)
# 1. https://web3forms.com → access key (ej. mismo UUID que Remote Config web_3_form)
# 2. Público para el cliente (plan gratuito; el envío server-side suele exigir plan + IP)
# =============================================================================
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key
# Opcional: solo si llamas Web3Forms desde API/server con plan Pro + IP permitida
# WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# =============================================================================
# Resend — correo de agradecimiento al usuario tras reservar (solo servidor, nunca en cliente)
# https://resend.com/api-keys — no subas la clave a git; rota si se filtra
# RESEND_FROM: "correo@dominio-verificado.com" o "Nombre <correo@dominio.com>"
# onboarding@resend.dev solo para pruebas: Resend solo deja enviar a TU correo verificado en la cuenta.
# En local, si pruebas el formulario con otro email, redirige el thank-you al verificado:
# RESEND_DEV_OVERRIDE_TO=mismo_correo_verificado_en_resend@ejemplo.com
# En producción: verifica un dominio en Resend y usa RESEND_FROM con ese dominio.
# La API /api/waitlist aplica rate limit por IP (ver lib/waitlist-api-security.ts)
# =============================================================================
# RESEND_API_KEY=re_xxxxxxxx
# (Opcional si ya está en Remote Config como resend_api_key y FIREBASE_ADMIN_SDK_KEY en el host)
# RESEND_FROM=Kevin Morales <info@devlokos.com>
# Plantilla publicada en Resend (npm run resend:publish-waitlist-template); si falta, se usa HTML inline.
# Tras publicar, edita variables reservadas: no uses FIRST_NAME en plantillas (Resend lo bloquea); el repo usa READER_NAME.
# RESEND_WAITLIST_TEMPLATE_ID=tpl_xxxxxxxx

# Lista de espera del libro: por defecto abierta (Firestore/Web3Forms + modal).
# Para modo “Próximamente” y API 403: NEXT_PUBLIC_WAITLIST_OPEN=false
# NEXT_PUBLIC_WAITLIST_OPEN=false

# =============================================================================
# Firebase Admin SDK - necesario para leer Remote Config (web_3_form, youtube_api_key, resend_api_key)
# Firebase Console → Project Settings → Service accounts → Generate new private key
# El JSON completo entre comillas simples (recomendado en Vercel y local)
# =============================================================================
# FIREBASE_ADMIN_SDK_KEY='{"type":"service_account","project_id":"...",...}'
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# (local) Si el JSON está en la raíz del repo: ./Kevinho Morales Firebase Admin SDK.json — añádelo a .gitignore

# Firebase - analytics, Firestore, Remote Config (service account: FIREBASE_ADMIN_SDK_KEY)
# Get config at: https://console.firebase.google.com/ → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=kevinho-morales.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=kevinho-morales
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=kevinho-morales.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=76842947951
NEXT_PUBLIC_FIREBASE_APP_ID=1:76842947951:web:9fb725d51a62b92c91c49a
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-PMNVBG0PK3

# =============================================================================
# Google Search Console (opcional): meta verification + mejor lectura del tráfico orgánico
# Search Console → Añadir propiedad → Etiqueta HTML → copiar solo el contenido del meta content
# =============================================================================
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token

# =============================================================================
# Panel admin (/admin)
# Login: Firebase Authentication (Email/contraseña). Actívalo en Console → Authentication.
# Crea el usuario con el mismo correo/clave con el que entrarás en /admin/login.
# Opcional: restringe qué correos pueden usar las APIs del panel (coma-separados):
# ADMIN_ALLOWED_EMAILS=tu@correo.com
# Firestore (contenido): raíz típica "prod" → documento "admin" → conferences / projects
#   Otra raíz: NEXT_PUBLIC_FIRESTORE_ROOT_COLLECTION=nombre
# APIs /api/admin/* verifican el ID token del cliente (Bearer) con Admin SDK.
# Lista de espera (popup): el POST /api/waitlist guarda en Firestore bajo prod/admin/waitlist — requiere este Admin SDK en servidor.
# Sitio público: FIREBASE_ADMIN_SDK_KEY o GOOGLE_APPLICATION_CREDENTIALS para SSR Firestore; sin key usa content/*.json
# En next dev la home NO llama Firestore por defecto (carga rápida). Para leer Firestore también en dev:
# DEV_FETCH_FIRESTORE=1
# =============================================================================
