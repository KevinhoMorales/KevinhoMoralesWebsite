rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /prod/admin/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* Imágenes de charlas subidas desde el panel (prod/conferences/conference001/…) */
    match /prod/conferences/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
